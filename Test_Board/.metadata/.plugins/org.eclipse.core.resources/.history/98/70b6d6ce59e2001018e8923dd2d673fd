#include "bmi270.h"

// --- helpers ---
static inline void cs_low(bmi270_t *dev)  { HAL_GPIO_WritePin(dev->cs_port, dev->cs_pin, GPIO_PIN_RESET); }
static inline void cs_high(bmi270_t *dev) { HAL_GPIO_WritePin(dev->cs_port, dev->cs_pin, GPIO_PIN_SET); }

// Per datasheet SPI read: first byte returned is dummy; for n bytes you must clock n+1 bytes and drop the first.
// Also R/W bit is bit7 of address (1=read).  :contentReference[oaicite:5]{index=5}
HAL_StatusTypeDef bmi270_read_reg(bmi270_t *dev, uint8_t reg, uint8_t *val)
{
    uint8_t tx[2] = { (uint8_t)(reg | 0x80), 0x00 };
    uint8_t rx[2] = { 0 };

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_TransmitReceive(dev->hspi, tx, rx, 2, 100);
    cs_high(dev);

    if (st != HAL_OK) return st;
    *val = rx[1]; // rx[0] dummy, rx[1] data
    return HAL_OK;
}

HAL_StatusTypeDef bmi270_read_regs(bmi270_t *dev, uint8_t reg, uint8_t *buf, uint16_t len)
{
    // Need len+1 clocks: 1 dummy then len data bytes. :contentReference[oaicite:6]{index=6}
    uint16_t n = (uint16_t)(len + 1);

    // Small stack limit guard: you can switch to static buffer if you want huge reads
    if (n > 64) return HAL_ERROR;

    uint8_t tx[64];
    uint8_t rx[64];

    tx[0] = (uint8_t)(reg | 0x80);
    for (uint16_t i = 1; i < n; i++) tx[i] = 0x00;

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_TransmitReceive(dev->hspi, tx, rx, n, 200);
    cs_high(dev);

    if (st != HAL_OK) return st;

    for (uint16_t i = 0; i < len; i++) buf[i] = rx[i + 1]; // drop dummy
    return HAL_OK;
}

HAL_StatusTypeDef bmi270_write_reg(bmi270_t *dev, uint8_t reg, uint8_t val)
{
    uint8_t tx[2] = { (uint8_t)(reg & 0x7F), val };

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_Transmit(dev->hspi, tx, 2, 100);
    cs_high(dev);

    // datasheet recommends idle time after write; STM32 HAL + small delays usually ok
    return st;
}

bool bmi270_begin(bmi270_t *dev,
                  SPI_HandleTypeDef *hspi,
                  GPIO_TypeDef *cs_port,
                  uint16_t cs_pin)
{
    if (!dev || !hspi || !cs_port) return false;

    dev->hspi = hspi;
    dev->cs_port = cs_port;
    dev->cs_pin = cs_pin;
    dev->acc_range_reg = 0x03; // default our init sets 16g
    dev->gyr_range_reg = 0x00; // default our init sets 2000 dps

    // Ensure CS high (inactive)
    cs_high(dev);
    HAL_Delay(5);

    return true;
}

static bool bmi270_softreset_and_select_spi(bmi270_t *dev)
{
    // Datasheet: after power-up device is in I2C, SPI is selected by CSB rising edge after power-up.
    // Bosch recommends doing a dummy CHIP_ID read first (invalid) to select SPI. :contentReference[oaicite:7]{index=7}
    uint8_t throwaway = 0;

    // Create a CS edge and dummy read
    cs_low(dev);
    HAL_Delay(1);
    cs_high(dev);
    HAL_Delay(1);

    (void)bmi270_read_reg(dev, BMI270_REG_CHIP_ID, &throwaway);

    // Soft reset
    if (bmi270_write_reg(dev, BMI270_REG_CMD, BMI270_CMD_SOFTRESET) != HAL_OK) return false;
    HAL_Delay(10);

    // Do the SPI-select dummy read again after reset (safe)
    (void)bmi270_read_reg(dev, BMI270_REG_CHIP_ID, &throwaway);
    HAL_Delay(2);

    return true;
}

bool bmi270_init_basic(bmi270_t *dev)
{
    if (!dev) return false;

    if (!bmi270_softreset_and_select_spi(dev))
        return false;

    // Verify CHIP_ID
    uint8_t chip = 0;
    if (bmi270_read_reg(dev, BMI270_REG_CHIP_ID, &chip) != HAL_OK) return false;
    if (chip != BMI270_CHIP_ID_VALUE) return false;

    // Optional: set PWR_CONF (fast power-up, etc.). We keep defaults unless you need otherwise.
    // PWR_CONF reset is 0x03 per datasheet. :contentReference[oaicite:8]{index=8}
    // Example: enable fast power up (bit2=1) while keeping others default:
    // read-modify-write if you want. For now we leave it.

    // Enable accel + gyro (temp optional)
    // PWR_CTRL bits: 1=gyr_en, 2=acc_en, 3=temp_en. :contentReference[oaicite:9]{index=9}
    if (bmi270_write_reg(dev, BMI270_REG_PWR_CTRL, 0x06) != HAL_OK) return false; // accel + gyro
    HAL_Delay(10);

    // Configure accel: ODR/filter in ACC_CONF. We'll set ODR=200Hz, normal mode-ish.
    // ACC_CONF format is bitfields; safest is to use a known driver if you need exact perf tuning.
    // For basic “does it move?” bring-up, this is fine.
    // Common: odr=0x09 (200Hz) and bwp=normal. (See ACC_CONF table in datasheet.)
    // We'll set: acc_odr=200Hz (0x09) and acc_bwp=normal (0x02 at bits 5:4). :contentReference[oaicite:10]{index=10}
    uint8_t acc_conf = (uint8_t)((0x02 << 4) | 0x09);
    if (bmi270_write_reg(dev, BMI270_REG_ACC_CONF, acc_conf) != HAL_OK) return false;

    // ACC_RANGE: 16g = 0x03 (datasheet register map) :contentReference[oaicite:11]{index=11}
    dev->acc_range_reg = 0x03;
    if (bmi270_write_reg(dev, BMI270_REG_ACC_RANGE, dev->acc_range_reg) != HAL_OK) return false;

    // Configure gyro: ODR=200Hz, normal bwp
    uint8_t gyr_conf = (uint8_t)((0x02 << 4) | 0x09);
    if (bmi270_write_reg(dev, BMI270_REG_GYR_CONF, gyr_conf) != HAL_OK) return false;

    // GYR_RANGE: 2000 dps = 0x00 :contentReference[oaicite:12]{index=12}
    dev->gyr_range_reg = 0x00;
    if (bmi270_write_reg(dev, BMI270_REG_GYR_RANGE, dev->gyr_range_reg) != HAL_OK) return false;

    HAL_Delay(5);

    return true;
}

bool bmi270_read_raw(bmi270_t *dev, bmi270_raw_t *out)
{
    if (!dev || !out) return false;

    uint8_t buf[BMI270_REG_DATA_LEN] = {0};
    if (bmi270_read_regs(dev, BMI270_REG_DATA_8, buf, BMI270_REG_DATA_LEN) != HAL_OK) return false;

    // little-endian
    out->ax = (int16_t)((buf[1] << 8) | buf[0]);
    out->ay = (int16_t)((buf[3] << 8) | buf[2]);
    out->az = (int16_t)((buf[5] << 8) | buf[4]);

    out->gx = (int16_t)((buf[7] << 8) | buf[6]);
    out->gy = (int16_t)((buf[9] << 8) | buf[8]);
    out->gz = (int16_t)((buf[11] << 8) | buf[10]);

    return true;
}

// Convert raw to g and dps using datasheet sensitivities.
// accel: ±16g => 2048 LSB/g (16-bit signed) typical BMI map.
// gyro: ±2000 dps => 16.4 LSB/dps. :contentReference[oaicite:13]{index=13}
void bmi270_scale(const bmi270_t *dev, const bmi270_raw_t *raw, bmi270_scaled_t *out)
{
    if (!dev || !raw || !out) return;

    float acc_lsb_per_g = 2048.0f; // for 16g
    switch (dev->acc_range_reg & 0x03) {
        case 0x00: acc_lsb_per_g = 16384.0f; break; // 2g
        case 0x01: acc_lsb_per_g = 8192.0f;  break; // 4g
        case 0x02: acc_lsb_per_g = 4096.0f;  break; // 8g
        case 0x03: acc_lsb_per_g = 2048.0f;  break; // 16g
        default:   acc_lsb_per_g = 2048.0f;  break;
    }

    float gyr_lsb_per_dps = 16.4f; // for 2000 dps
    switch (dev->gyr_range_reg & 0x07) {
        case 0x00: gyr_lsb_per_dps = 16.4f;  break; // 2000 dps :contentReference[oaicite:14]{index=14}
        case 0x01: gyr_lsb_per_dps = 32.8f;  break; // 1000
        case 0x02: gyr_lsb_per_dps = 65.6f;  break; // 500
        case 0x03: gyr_lsb_per_dps = 131.2f; break; // 250
        case 0x04: gyr_lsb_per_dps = 262.4f; break; // 125
        default:   gyr_lsb_per_dps = 16.4f;  break;
    }

    out->ax_g = raw->ax / acc_lsb_per_g;
    out->ay_g = raw->ay / acc_lsb_per_g;
    out->az_g = raw->az / acc_lsb_per_g;

    out->gx_dps = raw->gx / gyr_lsb_per_dps;
    out->gy_dps = raw->gy / gyr_lsb_per_dps;
    out->gz_dps = raw->gz / gyr_lsb_per_dps;
}
