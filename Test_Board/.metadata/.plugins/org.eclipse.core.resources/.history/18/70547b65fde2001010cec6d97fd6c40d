/**
 * @file bmi270.c
 * @brief BMI270 IMU Driver Implementation
 *
 * Based on verified sources:
 * - Bosch BMI270 Datasheet (BST-BMI270-DS000-07)
 * - Bosch BMI270_SensorAPI (bmi2.c upload_file function)
 * - Betaflight accgyro_spi_bmi270.c
 *
 * INITIALIZATION SEQUENCE (from datasheet Section 4.3):
 * 1. Wait 2ms after power-on
 * 2. Perform dummy SPI read to switch from I2C to SPI mode
 * 3. Verify chip ID (0x24)
 * 4. Soft reset (optional but recommended)
 * 5. Disable advanced power save (PWR_CONF = 0x00)
 * 6. Wait 450µs minimum
 * 7. Prepare config load (INIT_CTRL = 0x00)
 * 8. Write config file to INIT_DATA register
 * 9. Complete config load (INIT_CTRL = 0x01) - ONLY ONCE!
 * 10. Wait up to 150ms
 * 11. Verify INTERNAL_STATUS = 0x01
 * 12. Configure sensor settings
 */

#include "bmi270.h"
#include "bmi270_config.h"
#include <string.h>

/*============================================================================*/
/*                          PRIVATE CONSTANTS                                 */
/*============================================================================*/

/* SPI read/write bits */
#define BMI270_SPI_READ_BIT     0x80
#define BMI270_SPI_WRITE_MASK   0x7F

/* Timing constants (from datasheet) */
#define BMI270_POWER_ON_DELAY_MS        2
#define BMI270_SOFT_RESET_DELAY_MS      2
#define BMI270_ADV_PWR_SAVE_DELAY_US    450
#define BMI270_CONFIG_LOAD_DELAY_MS     150

/*============================================================================*/
/*                          PRIVATE FUNCTIONS                                 */
/*============================================================================*/

/**
 * @brief Assert CS (active low)
 */
static inline void cs_low(BMI270_Handle *dev)
{
    HAL_GPIO_WritePin(dev->cs_port, dev->cs_pin, GPIO_PIN_RESET);
}

/**
 * @brief Deassert CS
 */
static inline void cs_high(BMI270_Handle *dev)
{
    HAL_GPIO_WritePin(dev->cs_port, dev->cs_pin, GPIO_PIN_SET);
}

/**
 * @brief Delay in microseconds
 *
 * Note: HAL_Delay only supports milliseconds.
 * For accurate µs delays, use a timer or busy-wait.
 * Here we use a simple loop approximation.
 */
static void delay_us(uint32_t us)
{
    /* Rough approximation - adjust for your clock speed */
    volatile uint32_t count = us * 8;  /* ~72MHz clock */
    while (count--) {
        __NOP();
    }
}

/**
 * @brief Read single register
 *
 * BMI270 SPI read format: [addr | 0x80] [dummy] [data]
 * The dummy byte is required between address and data.
 */
static BMI270_Status spi_read_reg(BMI270_Handle *dev, uint8_t reg, uint8_t *val)
{
    uint8_t tx[3] = { reg | BMI270_SPI_READ_BIT, 0x00, 0x00 };
    uint8_t rx[3] = { 0 };

    cs_low(dev);
    HAL_StatusTypeDef status = HAL_SPI_TransmitReceive(dev->hspi, tx, rx, 3, 100);
    cs_high(dev);

    if (status != HAL_OK) {
        return BMI270_ERR_SPI;
    }

    *val = rx[2];  /* Data is in byte 2 (after addr and dummy) */
    return BMI270_OK;
}

/**
 * @brief Read multiple registers (burst read)
 *
 * Format: [addr | 0x80] [dummy] [data0] [data1] ... [dataN-1]
 */
static BMI270_Status spi_read_regs(BMI270_Handle *dev, uint8_t reg,
                                    uint8_t *buf, uint16_t len)
{
    /* Limit to prevent stack overflow */
    if (len > 64) {
        return BMI270_ERR_SPI;
    }

    uint8_t tx[68] = { 0 };  /* Max 64 data + 2 header bytes */
    uint8_t rx[68] = { 0 };
    uint16_t total = len + 2;  /* addr + dummy + data bytes */

    tx[0] = reg | BMI270_SPI_READ_BIT;
    /* tx[1] = 0x00 (dummy) - already initialized */

    cs_low(dev);
    HAL_StatusTypeDef status = HAL_SPI_TransmitReceive(dev->hspi, tx, rx, total, 100);
    cs_high(dev);

    if (status != HAL_OK) {
        return BMI270_ERR_SPI;
    }

    /* Data starts at rx[2] */
    memcpy(buf, &rx[2], len);
    return BMI270_OK;
}

/**
 * @brief Write single register
 *
 * Format: [addr & 0x7F] [data]
 */
static BMI270_Status spi_write_reg(BMI270_Handle *dev, uint8_t reg, uint8_t val)
{
    uint8_t tx[2] = { reg & BMI270_SPI_WRITE_MASK, val };

    cs_low(dev);
    HAL_StatusTypeDef status = HAL_SPI_Transmit(dev->hspi, tx, 2, 100);
    cs_high(dev);

    return (status == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/**
 * @brief Write multiple bytes (burst write)
 *
 * Used for config file upload.
 * Format: [addr & 0x7F] [data0] [data1] ... [dataN-1]
 */
static BMI270_Status spi_write_regs(BMI270_Handle *dev, uint8_t reg,
                                     const uint8_t *buf, uint16_t len)
{
    uint8_t addr = reg & BMI270_SPI_WRITE_MASK;

    cs_low(dev);

    /* Send address byte */
    HAL_StatusTypeDef status = HAL_SPI_Transmit(dev->hspi, &addr, 1, 100);
    if (status != HAL_OK) {
        cs_high(dev);
        return BMI270_ERR_SPI;
    }

    /* Send data bytes */
    status = HAL_SPI_Transmit(dev->hspi, (uint8_t *)buf, len, 1000);
    cs_high(dev);

    return (status == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/**
 * @brief Upload config file to BMI270
 *
 * Betaflight approach: Write entire 328-byte config in one burst.
 * This works because INIT_ADDR defaults to 0x0000 after reset.
 *
 * For larger config files (8192 bytes), you would need to write
 * in chunks and update INIT_ADDR before each chunk.
 */
static BMI270_Status upload_config(BMI270_Handle *dev)
{
    BMI270_Status st;

    /* 1. Disable advanced power save (required before config load) */
    st = spi_write_reg(dev, BMI270_REG_PWR_CONF, 0x00);
    if (st != BMI270_OK) return st;

    /* 2. Wait 450µs as per datasheet */
    delay_us(450);

    /* 3. Prepare for config load */
    st = spi_write_reg(dev, BMI270_REG_INIT_CTRL, 0x00);
    if (st != BMI270_OK) return st;

    /* 4. Write config file to INIT_DATA
     *
     * For 328-byte config: write in one burst (Betaflight method)
     * INIT_ADDR defaults to 0x0000, so no need to set it explicitly.
     */
    st = spi_write_regs(dev, BMI270_REG_INIT_DATA,
                        bmi270_config_file, BMI270_CONFIG_SIZE);
    if (st != BMI270_OK) return st;

    /* 5. Complete config load - THIS MUST ONLY BE DONE ONCE! */
    st = spi_write_reg(dev, BMI270_REG_INIT_CTRL, 0x01);
    if (st != BMI270_OK) return st;

    /* 6. Wait for initialization to complete */
    HAL_Delay(BMI270_CONFIG_LOAD_DELAY_MS);

    /* 7. Verify initialization status */
    uint8_t status;
    st = spi_read_reg(dev, BMI270_REG_INTERNAL_STATUS, &status);
    if (st != BMI270_OK) return st;

    dev->init_status = status & 0x0F;

    if (dev->init_status != BMI270_INIT_STATUS_OK) {
        return BMI270_ERR_CONFIG_LOAD;
    }

    return BMI270_OK;
}

/**
 * @brief Configure sensor after successful initialization
 */
static BMI270_Status configure_sensor(BMI270_Handle *dev)
{
    BMI270_Status st;

    /* Configure accelerometer:
     * - ODR: 800Hz (0x0B)
     * - BWP: OSR2 filter (0x01)
     * - Filter performance: High (0x01)
     * ACC_CONF = [filter_perf:1][bwp:2:0][odr:3:0] = 0xA9
     */
    st = spi_write_reg(dev, BMI270_REG_ACC_CONF, 0xA9);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    /* Set accelerometer range: 16g */
    st = spi_write_reg(dev, BMI270_REG_ACC_RANGE, BMI270_ACC_RANGE_16G);
    if (st != BMI270_OK) return st;
    dev->accel_scale = BMI270_ACC_SENS_16G;
    HAL_Delay(1);

    /* Configure gyroscope:
     * - ODR: 3200Hz (0x0D)
     * - BWP: OSR4 filter (0x00) - lowest noise
     * - Noise performance: High (0x01)
     * - Filter performance: High (0x01)
     * GYR_CONF = [filter_perf:1][noise_perf:1][bwp:1:0][odr:3:0] = 0xE9
     */
    st = spi_write_reg(dev, BMI270_REG_GYR_CONF, 0xE9);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    /* Set gyroscope range: 2000 dps
     * Note: Bit 3 (ois_range) must be set for 2000dps in FIFO mode
     */
    st = spi_write_reg(dev, BMI270_REG_GYR_RANGE, BMI270_GYR_RANGE_2000DPS | 0x08);
    if (st != BMI270_OK) return st;
    dev->gyro_scale = BMI270_GYR_SENS_2000DPS;
    HAL_Delay(1);

    /* Enable accelerometer, gyroscope, and temperature sensor
     * PWR_CTRL: [temp_en][gyr_en][acc_en][aux_en] = 0x0E
     */
    st = spi_write_reg(dev, BMI270_REG_PWR_CTRL, 0x0E);
    if (st != BMI270_OK) return st;

    /* Wait for sensors to stabilize */
    HAL_Delay(50);

    return BMI270_OK;
}

/*============================================================================*/
/*                          PUBLIC API FUNCTIONS                              */
/*============================================================================*/

BMI270_Status BMI270_SoftReset(BMI270_Handle *dev)
{
    if (dev == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    BMI270_Status st = spi_write_reg(dev, BMI270_REG_CMD, BMI270_CMD_SOFTRESET);
    if (st != BMI270_OK) return st;

    HAL_Delay(BMI270_SOFT_RESET_DELAY_MS);

    /* After reset, need dummy read to re-enter SPI mode */
    uint8_t dummy;
    spi_read_reg(dev, BMI270_REG_CHIP_ID, &dummy);
    HAL_Delay(1);

    return BMI270_OK;
}

BMI270_Status BMI270_ReadChipID(BMI270_Handle *dev, uint8_t *id)
{
    if (dev == NULL || id == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    return spi_read_reg(dev, BMI270_REG_CHIP_ID, id);
}

BMI270_Status BMI270_Init(BMI270_Handle *dev, SPI_HandleTypeDef *hspi,
                          GPIO_TypeDef *cs_port, uint16_t cs_pin)
{
    if (dev == NULL || hspi == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    /* Initialize handle */
    dev->hspi = hspi;
    dev->cs_port = cs_port;
    dev->cs_pin = cs_pin;
    dev->initialized = false;
    dev->accel_scale = BMI270_ACC_SENS_16G;  /* Default */
    dev->gyro_scale = BMI270_GYR_SENS_2000DPS;  /* Default */

    /* Ensure CS starts high (deasserted) */
    cs_high(dev);
    HAL_Delay(BMI270_POWER_ON_DELAY_MS);

    /* Dummy read to switch from I2C to SPI mode */
    uint8_t dummy;
    spi_read_reg(dev, BMI270_REG_CHIP_ID, &dummy);
    HAL_Delay(1);

    /* Soft reset for clean state */
    BMI270_Status st = BMI270_SoftReset(dev);
    if (st != BMI270_OK) return st;

    /* Verify chip ID */
    st = spi_read_reg(dev, BMI270_REG_CHIP_ID, &dev->chip_id);
    if (st != BMI270_OK) return st;

    if (dev->chip_id != BMI270_CHIP_ID_VALUE) {
        return BMI270_ERR_CHIP_ID;
    }

    /* Upload config file */
    st = upload_config(dev);
    if (st != BMI270_OK) return st;

    /* Configure sensor settings */
    st = configure_sensor(dev);
    if (st != BMI270_OK) return st;

    dev->initialized = true;
    return BMI270_OK;
}

BMI270_Status BMI270_ReadSensorData(BMI270_Handle *dev, BMI270_Data *data)
{
    if (dev == NULL || data == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    if (!dev->initialized) {
        return BMI270_ERR_NOT_READY;
    }

    /* Burst read accel (6 bytes) + gyro (6 bytes) = 12 bytes
     * Starting from ACC_X_LSB (0x0C)
     */
    uint8_t buf[12];
    BMI270_Status st = spi_read_regs(dev, BMI270_REG_ACC_X_LSB, buf, 12);
    if (st != BMI270_OK) return st;

    /* Parse accelerometer data (LSB first) */
    data->accel_raw.x = (int16_t)(buf[0] | (buf[1] << 8));
    data->accel_raw.y = (int16_t)(buf[2] | (buf[3] << 8));
    data->accel_raw.z = (int16_t)(buf[4] | (buf[5] << 8));

    /* Parse gyroscope data (LSB first) */
    data->gyro_raw.x = (int16_t)(buf[6] | (buf[7] << 8));
    data->gyro_raw.y = (int16_t)(buf[8] | (buf[9] << 8));
    data->gyro_raw.z = (int16_t)(buf[10] | (buf[11] << 8));

    /* Convert to physical units */
    data->accel_g.x = (float)data->accel_raw.x / dev->accel_scale;
    data->accel_g.y = (float)data->accel_raw.y / dev->accel_scale;
    data->accel_g.z = (float)data->accel_raw.z / dev->accel_scale;

    data->gyro_dps.x = (float)data->gyro_raw.x / dev->gyro_scale;
    data->gyro_dps.y = (float)data->gyro_raw.y / dev->gyro_scale;
    data->gyro_dps.z = (float)data->gyro_raw.z / dev->gyro_scale;

    return BMI270_OK;
}

BMI270_Status BMI270_ReadTemperature(BMI270_Handle *dev, float *temp_c)
{
    if (dev == NULL || temp_c == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    if (!dev->initialized) {
        return BMI270_ERR_NOT_READY;
    }

    uint8_t buf[2];
    BMI270_Status st = spi_read_regs(dev, BMI270_REG_TEMPERATURE_0, buf, 2);
    if (st != BMI270_OK) return st;

    int16_t temp_raw = (int16_t)(buf[0] | (buf[1] << 8));

    /* Convert to Celsius: T = 23 + raw/512 */
    if (temp_raw == (int16_t)0x8000) {
        *temp_c = 0.0f;  /* Invalid reading */
    } else {
        *temp_c = 23.0f + ((float)temp_raw / 512.0f);
    }

    return BMI270_OK;
}

BMI270_Status BMI270_SetAccelRange(BMI270_Handle *dev, uint8_t range)
{
    if (dev == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    BMI270_Status st = spi_write_reg(dev, BMI270_REG_ACC_RANGE, range);
    if (st != BMI270_OK) return st;

    /* Update scale factor */
    switch (range) {
        case BMI270_ACC_RANGE_2G:  dev->accel_scale = BMI270_ACC_SENS_2G;  break;
        case BMI270_ACC_RANGE_4G:  dev->accel_scale = BMI270_ACC_SENS_4G;  break;
        case BMI270_ACC_RANGE_8G:  dev->accel_scale = BMI270_ACC_SENS_8G;  break;
        case BMI270_ACC_RANGE_16G: dev->accel_scale = BMI270_ACC_SENS_16G; break;
        default: return BMI270_ERR_SPI;
    }

    return BMI270_OK;
}

BMI270_Status BMI270_SetGyroRange(BMI270_Handle *dev, uint8_t range)
{
    if (dev == NULL) {
        return BMI270_ERR_NULL_PTR;
    }

    /* Set bit 3 (ois_range) for proper operation in all modes */
    BMI270_Status st = spi_write_reg(dev, BMI270_REG_GYR_RANGE, range | 0x08);
    if (st != BMI270_OK) return st;

    /* Update scale factor */
    switch (range & 0x07) {
        case BMI270_GYR_RANGE_2000DPS: dev->gyro_scale = BMI270_GYR_SENS_2000DPS; break;
        case BMI270_GYR_RANGE_1000DPS: dev->gyro_scale = BMI270_GYR_SENS_1000DPS; break;
        case BMI270_GYR_RANGE_500DPS:  dev->gyro_scale = BMI270_GYR_SENS_500DPS;  break;
        case BMI270_GYR_RANGE_250DPS:  dev->gyro_scale = BMI270_GYR_SENS_250DPS;  break;
        case BMI270_GYR_RANGE_125DPS:  dev->gyro_scale = BMI270_GYR_SENS_125DPS;  break;
        default: return BMI270_ERR_SPI;
    }

    return BMI270_OK;
}
