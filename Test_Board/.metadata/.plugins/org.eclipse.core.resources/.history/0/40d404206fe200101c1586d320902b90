/**
 * @file bmp388.h
 * @brief BMP388 Barometric Pressure Sensor Driver for STM32 HAL (I2C)
 *
 * Based on Bosch BMP388 Datasheet BST-BMP388-DS001-07
 * Reference: Bosch BMP3-Sensor-API
 */

#ifndef BMP388_H
#define BMP388_H

#include "stm32h1xx_hal.h"
#include <stdint.h>
#include <stdbool.h>

/*===========================================================================*/
/* I2C Address                                                               */
/*===========================================================================*/
#define BMP388_I2C_ADDR_LOW     0x76    // SDO pin connected to GND
#define BMP388_I2C_ADDR_HIGH    0x77    // SDO pin connected to VDDIO

/*===========================================================================*/
/* Register Addresses                                                        */
/*===========================================================================*/
#define BMP388_REG_CHIP_ID      0x00
#define BMP388_REG_ERR_REG      0x02
#define BMP388_REG_STATUS       0x03
#define BMP388_REG_DATA_0       0x04    // Pressure XLSB
#define BMP388_REG_DATA_1       0x05    // Pressure LSB
#define BMP388_REG_DATA_2       0x06    // Pressure MSB
#define BMP388_REG_DATA_3       0x07    // Temperature XLSB
#define BMP388_REG_DATA_4       0x08    // Temperature LSB
#define BMP388_REG_DATA_5       0x09    // Temperature MSB
#define BMP388_REG_SENSORTIME_0 0x0C
#define BMP388_REG_SENSORTIME_1 0x0D
#define BMP388_REG_SENSORTIME_2 0x0E
#define BMP388_REG_EVENT        0x10
#define BMP388_REG_INT_STATUS   0x11
#define BMP388_REG_FIFO_LENGTH_0 0x12
#define BMP388_REG_FIFO_LENGTH_1 0x13
#define BMP388_REG_FIFO_DATA    0x14
#define BMP388_REG_FIFO_WTM_0   0x15
#define BMP388_REG_FIFO_WTM_1   0x16
#define BMP388_REG_FIFO_CONFIG_1 0x17
#define BMP388_REG_FIFO_CONFIG_2 0x18
#define BMP388_REG_INT_CTRL     0x19
#define BMP388_REG_IF_CONF      0x1A
#define BMP388_REG_PWR_CTRL     0x1B
#define BMP388_REG_OSR          0x1C    // Oversampling settings
#define BMP388_REG_ODR          0x1D    // Output data rate
#define BMP388_REG_CONFIG       0x1F    // IIR filter config
#define BMP388_REG_CALIB_DATA   0x31    // Start of calibration data (21 bytes)
#define BMP388_REG_CMD          0x7E

/*===========================================================================*/
/* Chip ID                                                                   */
/*===========================================================================*/
#define BMP388_CHIP_ID          0x50
#define BMP390_CHIP_ID          0x60    // In case you have BMP390

/*===========================================================================*/
/* Commands                                                                  */
/*===========================================================================*/
#define BMP388_CMD_SOFT_RESET   0xB6
#define BMP388_CMD_FIFO_FLUSH   0xB0

/*===========================================================================*/
/* Power Control Register Bits                                               */
/*===========================================================================*/
#define BMP388_PWR_PRESS_EN     0x01
#define BMP388_PWR_TEMP_EN      0x02
#define BMP388_PWR_MODE_SLEEP   (0x00 << 4)
#define BMP388_PWR_MODE_FORCED  (0x01 << 4)
#define BMP388_PWR_MODE_NORMAL  (0x03 << 4)

/*===========================================================================*/
/* Oversampling Settings                                                     */
/*===========================================================================*/
typedef enum {
    BMP388_OSR_x1   = 0x00,
    BMP388_OSR_x2   = 0x01,
    BMP388_OSR_x4   = 0x02,
    BMP388_OSR_x8   = 0x03,
    BMP388_OSR_x16  = 0x04,
    BMP388_OSR_x32  = 0x05
} BMP388_Oversampling;

/*===========================================================================*/
/* IIR Filter Coefficients                                                   */
/*===========================================================================*/
typedef enum {
    BMP388_IIR_COEF_0   = 0x00,     // Bypass (off)
    BMP388_IIR_COEF_1   = 0x01,
    BMP388_IIR_COEF_3   = 0x02,
    BMP388_IIR_COEF_7   = 0x03,
    BMP388_IIR_COEF_15  = 0x04,
    BMP388_IIR_COEF_31  = 0x05,
    BMP388_IIR_COEF_63  = 0x06,
    BMP388_IIR_COEF_127 = 0x07
} BMP388_IIR_Filter;

/*===========================================================================*/
/* Output Data Rate (ODR)                                                    */
/*===========================================================================*/
typedef enum {
    BMP388_ODR_200_HZ   = 0x00,
    BMP388_ODR_100_HZ   = 0x01,
    BMP388_ODR_50_HZ    = 0x02,
    BMP388_ODR_25_HZ    = 0x03,
    BMP388_ODR_12_5_HZ  = 0x04,
    BMP388_ODR_6_25_HZ  = 0x05,
    BMP388_ODR_3_1_HZ   = 0x06,
    BMP388_ODR_1_5_HZ   = 0x07,
    BMP388_ODR_0_78_HZ  = 0x08,
    BMP388_ODR_0_39_HZ  = 0x09,
    BMP388_ODR_0_2_HZ   = 0x0A,
    BMP388_ODR_0_1_HZ   = 0x0B,
    BMP388_ODR_0_05_HZ  = 0x0C,
    BMP388_ODR_0_02_HZ  = 0x0D,
    BMP388_ODR_0_01_HZ  = 0x0E,
    BMP388_ODR_0_006_HZ = 0x0F,
    BMP388_ODR_0_003_HZ = 0x10,
    BMP388_ODR_0_0015_HZ = 0x11
} BMP388_ODR;

/*===========================================================================*/
/* Status Register Bits                                                      */
/*===========================================================================*/
#define BMP388_STATUS_CMD_RDY       0x10
#define BMP388_STATUS_DRDY_PRESS    0x20
#define BMP388_STATUS_DRDY_TEMP     0x40

/*===========================================================================*/
/* Error Codes                                                               */
/*===========================================================================*/
typedef enum {
    BMP388_OK = 0,
    BMP388_ERR_NULL_PTR,
    BMP388_ERR_COMM,
    BMP388_ERR_CHIP_ID,
    BMP388_ERR_CONFIG,
    BMP388_ERR_NOT_READY,
    BMP388_ERR_TIMEOUT
} BMP388_Status;

/*===========================================================================*/
/* Calibration Data Structure (from NVM)                                     */
/* Reference: Datasheet Table 22                                             */
/*===========================================================================*/
typedef struct {
    // Temperature calibration coefficients
    uint16_t par_t1;
    uint16_t par_t2;
    int8_t   par_t3;

    // Pressure calibration coefficients
    int16_t  par_p1;
    int16_t  par_p2;
    int8_t   par_p3;
    int8_t   par_p4;
    uint16_t par_p5;
    uint16_t par_p6;
    int8_t   par_p7;
    int8_t   par_p8;
    int16_t  par_p9;
    int8_t   par_p10;
    int8_t   par_p11;
} BMP388_CalibData;

/*===========================================================================*/
/* Quantized Calibration Coefficients (for compensation)                     */
/*===========================================================================*/
typedef struct {
    double par_t1;
    double par_t2;
    double par_t3;
    double par_p1;
    double par_p2;
    double par_p3;
    double par_p4;
    double par_p5;
    double par_p6;
    double par_p7;
    double par_p8;
    double par_p9;
    double par_p10;
    double par_p11;
} BMP388_QuantizedCalibData;

/*===========================================================================*/
/* Configuration Structure                                                   */
/*===========================================================================*/
typedef struct {
    BMP388_Oversampling osr_press;
    BMP388_Oversampling osr_temp;
    BMP388_IIR_Filter   iir_filter;
    BMP388_ODR          odr;
} BMP388_Config;

/*===========================================================================*/
/* Device Handle Structure                                                   */
/*===========================================================================*/
typedef struct {
    I2C_HandleTypeDef   *hi2c;
    uint8_t             i2c_addr;       // 7-bit address (0x76 or 0x77)
    uint8_t             chip_id;
    BMP388_CalibData    calib;
    BMP388_QuantizedCalibData qcalib;   // Quantized coefficients
    double              t_lin;          // Linearized temperature (for pressure comp)
    BMP388_Config       config;
} BMP388_Handle;

/*===========================================================================*/
/* Measurement Data Structure                                                */
/*===========================================================================*/
typedef struct {
    double temperature;     // Temperature in degrees Celsius
    double pressure;        // Pressure in Pascals
    double altitude;        // Altitude in meters (calculated from sea level pressure)
} BMP388_Data;

/*===========================================================================*/
/* Function Prototypes                                                       */
/*===========================================================================*/

/**
 * @brief Initialize BMP388 sensor
 * @param dev Pointer to device handle
 * @param hi2c Pointer to I2C handle
 * @param addr I2C address (BMP388_I2C_ADDR_LOW or BMP388_I2C_ADDR_HIGH)
 * @return BMP388_Status
 */
BMP388_Status BMP388_Init(BMP388_Handle *dev, I2C_HandleTypeDef *hi2c, uint8_t addr);

/**
 * @brief Perform soft reset
 * @param dev Pointer to device handle
 * @return BMP388_Status
 */
BMP388_Status BMP388_SoftReset(BMP388_Handle *dev);

/**
 * @brief Configure sensor settings
 * @param dev Pointer to device handle
 * @param config Pointer to configuration structure
 * @return BMP388_Status
 */
BMP388_Status BMP388_Configure(BMP388_Handle *dev, BMP388_Config *config);

/**
 * @brief Set power mode
 * @param dev Pointer to device handle
 * @param mode Power mode (SLEEP, FORCED, NORMAL)
 * @return BMP388_Status
 */
BMP388_Status BMP388_SetPowerMode(BMP388_Handle *dev, uint8_t mode);

/**
 * @brief Check if data is ready
 * @param dev Pointer to device handle
 * @param ready Pointer to store ready status
 * @return BMP388_Status
 */
BMP388_Status BMP388_IsDataReady(BMP388_Handle *dev, bool *ready);

/**
 * @brief Read temperature and pressure (forced mode - triggers measurement)
 * @param dev Pointer to device handle
 * @param data Pointer to store measurement data
 * @return BMP388_Status
 */
BMP388_Status BMP388_ReadData(BMP388_Handle *dev, BMP388_Data *data);

/**
 * @brief Read temperature only
 * @param dev Pointer to device handle
 * @param temperature Pointer to store temperature in Celsius
 * @return BMP388_Status
 */
BMP388_Status BMP388_ReadTemperature(BMP388_Handle *dev, double *temperature);

/**
 * @brief Read pressure only
 * @param dev Pointer to device handle
 * @param pressure Pointer to store pressure in Pascals
 * @return BMP388_Status
 */
BMP388_Status BMP388_ReadPressure(BMP388_Handle *dev, double *pressure);

/**
 * @brief Calculate altitude from pressure
 * @param pressure Pressure in Pascals
 * @param sea_level_pressure Sea level pressure in Pascals (default: 101325 Pa)
 * @return Altitude in meters
 */
double BMP388_CalculateAltitude(double pressure, double sea_level_pressure);

/**
 * @brief Get chip ID
 * @param dev Pointer to device handle
 * @param chip_id Pointer to store chip ID
 * @return BMP388_Status
 */
BMP388_Status BMP388_GetChipID(BMP388_Handle *dev, uint8_t *chip_id);

/**
 * @brief Get error register value
 * @param dev Pointer to device handle
 * @param err Pointer to store error value
 * @return BMP388_Status
 */
BMP388_Status BMP388_GetError(BMP388_Handle *dev, uint8_t *err);

#endif /* BMP388_H */
