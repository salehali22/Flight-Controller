/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_I2C1_Init();
    MX_I2C2_Init();

    BMI270_Status status = BMI270_Init(&bmi270, &hspi1, BMI270_CS_PORT, BMI270_CS_PIN);

       bmi270_chip_id = bmi270.chip_id;
       bmi270_init_status = bmi270.init_status;

       if (status != BMI270_OK) {
           bmi270_error = (uint8_t)status;
           // Error handling - set breakpoint here to check bmi270_error
           // 1 = NULL ptr, 2 = SPI error, 3 = Wrong chip ID, 4 = Config failed, 5 = Not init
           while (1) {
               HAL_Delay(100);
           }
       }

       /*=========================================================================*/
       /*                           MAIN LOOP                                     */
       /*=========================================================================*/

       while (1)
       {
           // Read sensor data
           status = BMI270_ReadData(&bmi270, &imu_data);

           if (status == BMI270_OK) {
               // Copy to volatile variables for Live Expressions debugging
               accel_x = imu_data.accel_g.x;
               accel_y = imu_data.accel_g.y;
               accel_z = imu_data.accel_g.z;

               gyro_x = imu_data.gyro_dps.x;
               gyro_y = imu_data.gyro_dps.y;
               gyro_z = imu_data.gyro_dps.z;

               temp = imu_data.temp_c;
               sample_cnt = imu_data.sample_count;
           }

           HAL_Delay(10);  // ~100Hz read rate
       }
}

