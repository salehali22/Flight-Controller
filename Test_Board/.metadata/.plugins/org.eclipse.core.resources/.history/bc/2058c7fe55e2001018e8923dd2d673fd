/**
 * @file bmi270.h
 * @brief BMI270 6-axis IMU driver for STM32 HAL
 * @note Minimal driver for hardware verification
 */

#ifndef BMI270_H
#define BMI270_H

#include "stm32f1xx_hal.h"
#include <stdint.h>

/* ============== Configuration ============== */
#define BMI270_SPI              hspi1
#define BMI270_CS_PORT          GPIOB
#define BMI270_CS_PIN           GPIO_PIN_0

/* ============== Device ID ============== */
#define BMI270_CHIP_ID_VAL      0x24

/* ============== Register Map ============== */
#define BMI270_REG_CHIP_ID          0x00
#define BMI270_REG_ERR_REG          0x02
#define BMI270_REG_STATUS           0x03
#define BMI270_REG_ACC_X_LSB        0x0C
#define BMI270_REG_ACC_X_MSB        0x0D
#define BMI270_REG_ACC_Y_LSB        0x0E
#define BMI270_REG_ACC_Y_MSB        0x0F
#define BMI270_REG_ACC_Z_LSB        0x10
#define BMI270_REG_ACC_Z_MSB        0x11
#define BMI270_REG_GYR_X_LSB        0x12
#define BMI270_REG_GYR_X_MSB        0x13
#define BMI270_REG_GYR_Y_LSB        0x14
#define BMI270_REG_GYR_Y_MSB        0x15
#define BMI270_REG_GYR_Z_LSB        0x16
#define BMI270_REG_GYR_Z_MSB        0x17
#define BMI270_REG_SENSORTIME_0     0x18
#define BMI270_REG_SENSORTIME_1     0x19
#define BMI270_REG_SENSORTIME_2     0x1A
#define BMI270_REG_EVENT            0x1B
#define BMI270_REG_INT_STATUS_0     0x1C
#define BMI270_REG_INT_STATUS_1     0x1D
#define BMI270_REG_INTERNAL_STATUS  0x21
#define BMI270_REG_TEMPERATURE_LSB  0x22
#define BMI270_REG_TEMPERATURE_MSB  0x23
#define BMI270_REG_ACC_CONF         0x40
#define BMI270_REG_ACC_RANGE        0x41
#define BMI270_REG_GYR_CONF         0x42
#define BMI270_REG_GYR_RANGE        0x43
#define BMI270_REG_INT1_IO_CTRL     0x53
#define BMI270_REG_INT2_IO_CTRL     0x54
#define BMI270_REG_INT_LATCH        0x55
#define BMI270_REG_INT1_MAP_FEAT    0x56
#define BMI270_REG_INT2_MAP_FEAT    0x57
#define BMI270_REG_INT_MAP_DATA     0x58
#define BMI270_REG_INIT_CTRL        0x59
#define BMI270_REG_INIT_ADDR_0      0x5B
#define BMI270_REG_INIT_ADDR_1      0x5C
#define BMI270_REG_INIT_DATA        0x5E
#define BMI270_REG_PWR_CONF         0x7C
#define BMI270_REG_PWR_CTRL         0x7D
#define BMI270_REG_CMD              0x7E

/* ============== ACC_CONF Values ============== */
#define BMI270_ACC_ODR_100HZ        0x08
#define BMI270_ACC_ODR_200HZ        0x09
#define BMI270_ACC_ODR_400HZ        0x0A
#define BMI270_ACC_ODR_800HZ        0x0B
#define BMI270_ACC_ODR_1600HZ       0x0C
#define BMI270_ACC_BWP_NORMAL       (0x02 << 4)
#define BMI270_ACC_FILTER_PERF      (0x01 << 7)

/* ============== ACC_RANGE Values ============== */
#define BMI270_ACC_RANGE_2G         0x00
#define BMI270_ACC_RANGE_4G         0x01
#define BMI270_ACC_RANGE_8G         0x02
#define BMI270_ACC_RANGE_16G        0x03

/* ============== GYR_CONF Values ============== */
#define BMI270_GYR_ODR_100HZ        0x07
#define BMI270_GYR_ODR_200HZ        0x08
#define BMI270_GYR_ODR_400HZ        0x09
#define BMI270_GYR_ODR_800HZ        0x0A
#define BMI270_GYR_ODR_1600HZ       0x0B
#define BMI270_GYR_BWP_NORMAL       (0x02 << 4)
#define BMI270_GYR_NOISE_PERF       (0x01 << 6)
#define BMI270_GYR_FILTER_PERF      (0x01 << 7)

/* ============== GYR_RANGE Values ============== */
#define BMI270_GYR_RANGE_2000DPS    0x00
#define BMI270_GYR_RANGE_1000DPS    0x01
#define BMI270_GYR_RANGE_500DPS     0x02
#define BMI270_GYR_RANGE_250DPS     0x03
#define BMI270_GYR_RANGE_125DPS     0x04

/* ============== PWR_CTRL Bits ============== */
#define BMI270_PWR_ACC_EN           0x04
#define BMI270_PWR_GYR_EN           0x02
#define BMI270_PWR_TEMP_EN          0x01

/* ============== PWR_CONF Values ============== */
#define BMI270_PWR_CONF_ADV_PWR_SAVE    0x01

/* ============== CMD Values ============== */
#define BMI270_CMD_SOFTRESET        0xB6

/* ============== INTERNAL_STATUS Values ============== */
#define BMI270_INIT_OK              0x01

/* ============== Sensitivity ============== */
#define BMI270_ACCEL_SENS_16G       2048.0f   // LSB/g
#define BMI270_GYRO_SENS_2000DPS    16.4f     // LSB/dps
#define BMI270_TEMP_SENS            512.0f    // LSB/°C
#define BMI270_TEMP_OFFSET          23.0f     // °C

/* ============== Data Structures ============== */
typedef struct {
    int16_t x;
    int16_t y;
    int16_t z;
} BMI270_RawData_t;

typedef struct {
    float x;
    float y;
    float z;
} BMI270_ScaledData_t;

typedef struct {
    BMI270_RawData_t accel_raw;
    BMI270_RawData_t gyro_raw;
    int16_t temp_raw;

    BMI270_ScaledData_t accel_g;
    BMI270_ScaledData_t gyro_dps;
    float temp_c;
} BMI270_Data_t;

typedef enum {
    BMI270_OK = 0,
    BMI270_ERR_SPI,
    BMI270_ERR_ID,
    BMI270_ERR_INIT,
    BMI270_ERR_TIMEOUT
} BMI270_Status_t;

/* ============== Function Prototypes ============== */
BMI270_Status_t BMI270_Init(SPI_HandleTypeDef *hspi);
BMI270_Status_t BMI270_ReadID(SPI_HandleTypeDef *hspi, uint8_t *id);
BMI270_Status_t BMI270_ReadAll(SPI_HandleTypeDef *hspi, BMI270_Data_t *data);
BMI270_Status_t BMI270_ReadReg(SPI_HandleTypeDef *hspi, uint8_t reg, uint8_t *data);
BMI270_Status_t BMI270_WriteReg(SPI_HandleTypeDef *hspi, uint8_t reg, uint8_t data);

#endif /* BMI270_H */
