#define BMI270_CONFIG_SIZE sizeof(bmi270_config_file)
#define BMI270_SPI_TIMEOUT 100

/* CS control */
static inline void CS_Low(void) {
    HAL_GPIO_WritePin(BMI270_CS_PORT, BMI270_CS_PIN, GPIO_PIN_RESET);
}

static inline void CS_High(void) {
    HAL_GPIO_WritePin(BMI270_CS_PORT, BMI270_CS_PIN, GPIO_PIN_SET);
}

/* Read single register (BMI270 needs dummy byte after address) */
BMI270_Status_t BMI270_ReadReg(SPI_HandleTypeDef *hspi, uint8_t reg, uint8_t *data)
{
    uint8_t tx[3] = { reg | 0x80, 0x00, 0x00 };
    uint8_t rx[3] = { 0 };

    CS_Low();
    HAL_StatusTypeDef status = HAL_SPI_TransmitReceive(hspi, tx, rx, 3, BMI270_SPI_TIMEOUT);
    CS_High();

    *data = rx[2];
    return (status == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/* Write single register */
BMI270_Status_t BMI270_WriteReg(SPI_HandleTypeDef *hspi, uint8_t reg, uint8_t data)
{
    uint8_t tx[2] = { reg & 0x7F, data };

    CS_Low();
    HAL_StatusTypeDef status = HAL_SPI_Transmit(hspi, tx, 2, BMI270_SPI_TIMEOUT);
    CS_High();

    return (status == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/* Write burst (for config file) */
static BMI270_Status_t BMI270_WriteBurst(SPI_HandleTypeDef *hspi, uint8_t reg, const uint8_t *data, uint16_t len)
{
    uint8_t reg_addr = reg & 0x7F;

    CS_Low();
    HAL_StatusTypeDef status = HAL_SPI_Transmit(hspi, &reg_addr, 1, BMI270_SPI_TIMEOUT);
    if (status == HAL_OK) {
        status = HAL_SPI_Transmit(hspi, (uint8_t*)data, len, 1000);  // longer timeout for burst
    }
    CS_High();

    return (status == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/* Read burst */
static BMI270_Status_t BMI270_ReadBurst(SPI_HandleTypeDef *hspi, uint8_t reg, uint8_t *data, uint16_t len)
{
    uint8_t tx = reg | 0x80;
    uint8_t dummy;

    CS_Low();
    HAL_SPI_Transmit(hspi, &tx, 1, BMI270_SPI_TIMEOUT);
    HAL_SPI_Receive(hspi, &dummy, 1, BMI270_SPI_TIMEOUT);  // dummy byte
    HAL_StatusTypeDef status = HAL_SPI_Receive(hspi, data, len, BMI270_SPI_TIMEOUT);
    CS_High();

    return (status == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

BMI270_Status_t BMI270_ReadID(SPI_HandleTypeDef *hspi, uint8_t *id)
{
    return BMI270_ReadReg(hspi, BMI270_REG_CHIP_ID, id);
}

BMI270_Status_t BMI270_Init(SPI_HandleTypeDef *hspi)
{
    uint8_t data;

    CS_High();
    HAL_Delay(10);

    // Dummy read to enable SPI mode
    CS_Low();
    HAL_SPI_Receive(hspi, &data, 1, BMI270_SPI_TIMEOUT);
    CS_High();
    HAL_Delay(2);

    // Soft reset
    BMI270_WriteReg(hspi, BMI270_REG_CMD, 0xB6);
    HAL_Delay(10);

    // Another dummy read after reset
    CS_Low();
    HAL_SPI_Receive(hspi, &data, 1, BMI270_SPI_TIMEOUT);
    CS_High();
    HAL_Delay(2);

    // Verify chip ID
    BMI270_ReadReg(hspi, BMI270_REG_CHIP_ID, &data);
    if (data != 0x24) {
        return BMI270_ERR_ID;
    }

    // Disable advanced power save
    BMI270_WriteReg(hspi, BMI270_REG_PWR_CONF, 0x00);
    HAL_Delay(1);

    // Prepare config load
    BMI270_WriteReg(hspi, BMI270_REG_INIT_CTRL, 0x00);
    HAL_Delay(1);

    // Write config file in one burst (Betaflight style)
    BMI270_WriteBurst(hspi, BMI270_REG_INIT_DATA, bmi270_config_file, BMI270_CONFIG_SIZE);
    HAL_Delay(10);

    // Complete config load
    BMI270_WriteReg(hspi, BMI270_REG_INIT_CTRL, 0x01);
    HAL_Delay(200);

    // Check init status
    BMI270_ReadReg(hspi, BMI270_REG_INTERNAL_STATUS, &data);
    if ((data & 0x0F) != 0x01) {
        return BMI270_ERR_INIT;
    }

    // Configure accelerometer: 800Hz, OSR2, high perf
    BMI270_WriteReg(hspi, BMI270_REG_ACC_CONF, 0xA8);
    HAL_Delay(1);

    // Accel range: 16g
    BMI270_WriteReg(hspi, BMI270_REG_ACC_RANGE, 0x03);
    HAL_Delay(1);

    // Configure gyroscope: 3200Hz, OSR4, high perf
    BMI270_WriteReg(hspi, BMI270_REG_GYR_CONF, 0xAD);
    HAL_Delay(1);

    // Gyro range: 2000dps
    BMI270_WriteReg(hspi, BMI270_REG_GYR_RANGE, 0x08);
    HAL_Delay(1);

    // Enable accel + gyro
    BMI270_WriteReg(hspi, BMI270_REG_PWR_CTRL, 0x0E);
    HAL_Delay(100);

    return BMI270_OK;
}

BMI270_Status_t BMI270_ReadAll(SPI_HandleTypeDef *hspi, BMI270_Data_t *data)
{
    uint8_t buf[12];

    BMI270_ReadBurst(hspi, BMI270_REG_ACC_X_LSB, buf, 12);

    data->accel_raw.x = (int16_t)(buf[0] | (buf[1] << 8));
    data->accel_raw.y = (int16_t)(buf[2] | (buf[3] << 8));
    data->accel_raw.z = (int16_t)(buf[4] | (buf[5] << 8));

    data->gyro_raw.x = (int16_t)(buf[6] | (buf[7] << 8));
    data->gyro_raw.y = (int16_t)(buf[8] | (buf[9] << 8));
    data->gyro_raw.z = (int16_t)(buf[10] | (buf[11] << 8));

    data->accel_g.x = (float)data->accel_raw.x / 2048.0f;
    data->accel_g.y = (float)data->accel_raw.y / 2048.0f;
    data->accel_g.z = (float)data->accel_raw.z / 2048.0f;

    data->gyro_dps.x = (float)data->gyro_raw.x / 16.4f;
    data->gyro_dps.y = (float)data->gyro_raw.y / 16.4f;
    data->gyro_dps.z = (float)data->gyro_raw.z / 16.4f;

    return BMI270_OK;
}
