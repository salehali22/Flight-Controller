/**
 * @file bmi270.c
 * @brief BMI270 IMU Driver for STM32 HAL
 *
 * Based on Betaflight and Bosch official API
 *
 * KEY IMPLEMENTATION NOTES:
 * 1. SPI reads require 3 bytes: [addr|0x80, dummy, data]
 * 2. Config file must be uploaded before sensor works
 * 3. Wait 150ms after config upload for initialization
 */

#include "bmi270.h"
#include "bmi270_config.h"
#include <string.h>

/*============================================================================*/
/*                          INTERNAL FUNCTIONS                                */
/*============================================================================*/

static inline void cs_low(BMI270_Device *dev) {
    HAL_GPIO_WritePin(dev->cs_port, dev->cs_pin, GPIO_PIN_RESET);
}

static inline void cs_high(BMI270_Device *dev) {
    HAL_GPIO_WritePin(dev->cs_port, dev->cs_pin, GPIO_PIN_SET);
}

/**
 * @brief Read single register
 * BMI270 SPI read requires: [addr|0x80] [dummy] [data]
 * Data appears in byte 2 (index 2)
 */
static BMI270_Status spi_read_reg(BMI270_Device *dev, uint8_t reg, uint8_t *val)
{
    uint8_t tx[3] = { reg | 0x80, 0x00, 0x00 };
    uint8_t rx[3] = { 0 };

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_TransmitReceive(dev->hspi, tx, rx, 3, 100);
    cs_high(dev);

    if (st != HAL_OK) return BMI270_ERR_SPI;
    *val = rx[2];
    return BMI270_OK;
}

/**
 * @brief Read multiple registers (burst read)
 * Transaction: [addr|0x80] [dummy] [data0] [data1] ...
 */
static BMI270_Status spi_read_regs(BMI270_Device *dev, uint8_t reg, uint8_t *buf, uint16_t len)
{
    uint8_t tx[32] = { 0 };
    uint8_t rx[32] = { 0 };
    uint16_t total = len + 2;  // addr + dummy + data

    if (total > sizeof(tx)) return BMI270_ERR_SPI;

    tx[0] = reg | 0x80;

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_TransmitReceive(dev->hspi, tx, rx, total, 100);
    cs_high(dev);

    if (st != HAL_OK) return BMI270_ERR_SPI;
    memcpy(buf, &rx[2], len);
    return BMI270_OK;
}

/**
 * @brief Write single register
 */
static BMI270_Status spi_write_reg(BMI270_Device *dev, uint8_t reg, uint8_t val)
{
    uint8_t tx[2] = { reg & 0x7F, val };

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_Transmit(dev->hspi, tx, 2, 100);
    cs_high(dev);

    return (st == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/**
 * @brief Write buffer (for config upload)
 */
static BMI270_Status spi_write_buf(BMI270_Device *dev, uint8_t reg, const uint8_t *buf, uint16_t len)
{
    uint8_t addr = reg & 0x7F;

    cs_low(dev);
    HAL_StatusTypeDef st = HAL_SPI_Transmit(dev->hspi, &addr, 1, 100);
    if (st == HAL_OK) {
        st = HAL_SPI_Transmit(dev->hspi, (uint8_t*)buf, len, 1000);
    }
    cs_high(dev);

    return (st == HAL_OK) ? BMI270_OK : BMI270_ERR_SPI;
}

/**
 * @brief Upload config file to BMI270 (Betaflight method)
 */
static BMI270_Status upload_config(BMI270_Device *dev)
{
    BMI270_Status st;

    // Disable config loading
    st = spi_write_reg(dev, BMI270_REG_INIT_CTRL, 0x00);
    if (st != BMI270_OK) return st;
    HAL_Delay(10);

    // Burst write config file
    st = spi_write_buf(dev, BMI270_REG_INIT_DATA, bmi270_config_file, BMI270_CONFIG_SIZE);
    if (st != BMI270_OK) return st;
    HAL_Delay(10);

    // Enable config loading
    st = spi_write_reg(dev, BMI270_REG_INIT_CTRL, 0x01);
    if (st != BMI270_OK) return st;

    // Wait for initialization (datasheet: 140ms typical)
    HAL_Delay(150);

    // Check status
    uint8_t status;
    st = spi_read_reg(dev, BMI270_REG_INTERNAL_STATUS, &status);
    if (st != BMI270_OK) return st;

    dev->init_status = status & 0x0F;

    // 0x01 = init OK, 0x00 = not init, 0x02 = error
    if (dev->init_status != 0x01) {
        return BMI270_ERR_CONFIG;
    }

    return BMI270_OK;
}

/*============================================================================*/
/*                          PUBLIC API                                        */
/*============================================================================*/

BMI270_Status BMI270_Reset(BMI270_Device *dev)
{
    if (!dev) return BMI270_ERR_NULL;

    BMI270_Status st = spi_write_reg(dev, BMI270_REG_CMD, BMI270_CMD_SOFTRESET);
    if (st != BMI270_OK) return st;

    HAL_Delay(10);
    return BMI270_OK;
}

BMI270_Status BMI270_GetChipID(BMI270_Device *dev, uint8_t *id)
{
    if (!dev || !id) return BMI270_ERR_NULL;
    return spi_read_reg(dev, BMI270_REG_CHIP_ID, id);
}

BMI270_Status BMI270_Init(BMI270_Device *dev, SPI_HandleTypeDef *hspi,
                          GPIO_TypeDef *cs_port, uint16_t cs_pin)
{
    if (!dev || !hspi) return BMI270_ERR_NULL;

    // Initialize handle
    dev->hspi = hspi;
    dev->cs_port = cs_port;
    dev->cs_pin = cs_pin;
    dev->ready = false;
    dev->accel_scale = BMI270_ACC_SENS_16G;
    dev->gyro_scale = BMI270_GYR_SENS_2000DPS;

    // Ensure CS high
    cs_high(dev);
    HAL_Delay(10);

    // Dummy read to switch from I2C to SPI mode
    uint8_t dummy;
    spi_read_reg(dev, BMI270_REG_CHIP_ID, &dummy);
    HAL_Delay(2);

    // Soft reset
    BMI270_Reset(dev);
    HAL_Delay(50);

    // Dummy read after reset
    spi_read_reg(dev, BMI270_REG_CHIP_ID, &dummy);
    HAL_Delay(2);

    // Verify chip ID
    BMI270_Status st = BMI270_GetChipID(dev, &dev->chip_id);
    if (st != BMI270_OK) return st;
    if (dev->chip_id != BMI270_CHIP_ID) return BMI270_ERR_CHIP_ID;

    // Upload config file
    st = upload_config(dev);
    if (st != BMI270_OK) return st;

    // Disable advanced power save
    st = spi_write_reg(dev, BMI270_REG_PWR_CONF, 0x00);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    // Configure accelerometer: ODR=800Hz, OSR2, high-perf
    // ACC_CONF = [filter_perf:1][bwp:2][odr:4] = [1][01][1011] = 0xA8 or 0xA9
    st = spi_write_reg(dev, BMI270_REG_ACC_CONF, 0xA9);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    // Accelerometer range: 16g
    st = spi_write_reg(dev, BMI270_REG_ACC_RANGE, BMI270_ACC_RANGE_16G);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    // Configure gyroscope: ODR=3200Hz, OSR2, high-perf noise+filter
    // GYR_CONF = [filter_perf:1][noise_perf:1][bwp:2][odr:4] = [1][1][01][1101] = 0xE9
    st = spi_write_reg(dev, BMI270_REG_GYR_CONF, 0xE9);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    // Gyroscope range: 2000 dps
    st = spi_write_reg(dev, BMI270_REG_GYR_RANGE, BMI270_GYR_RANGE_2000DPS);
    if (st != BMI270_OK) return st;
    HAL_Delay(1);

    // Enable accel + gyro
    st = spi_write_reg(dev, BMI270_REG_PWR_CTRL, 0x0E);  // temp_en + gyr_en + acc_en
    if (st != BMI270_OK) return st;
    HAL_Delay(50);

    dev->ready = true;
    return BMI270_OK;
}

BMI270_Status BMI270_ReadData(BMI270_Device *dev, BMI270_Data *data)
{
    if (!dev || !data) return BMI270_ERR_NULL;
    if (!dev->ready) return BMI270_ERR_NOT_INIT;

    // Burst read accel (6) + gyro (6) = 12 bytes starting at 0x0C
    uint8_t buf[12];
    BMI270_Status st = spi_read_regs(dev, BMI270_REG_ACC_DATA_X_LSB, buf, 12);
    if (st != BMI270_OK) return st;

    // Parse accelerometer (LSB first)
    data->accel_raw.x = (int16_t)(buf[0] | (buf[1] << 8));
    data->accel_raw.y = (int16_t)(buf[2] | (buf[3] << 8));
    data->accel_raw.z = (int16_t)(buf[4] | (buf[5] << 8));

    // Parse gyroscope (LSB first)
    data->gyro_raw.x = (int16_t)(buf[6] | (buf[7] << 8));
    data->gyro_raw.y = (int16_t)(buf[8] | (buf[9] << 8));
    data->gyro_raw.z = (int16_t)(buf[10] | (buf[11] << 8));

    // Read temperature separately
    uint8_t temp_buf[2];
    st = spi_read_regs(dev, BMI270_REG_TEMP_LSB, temp_buf, 2);
    if (st != BMI270_OK) return st;

    int16_t temp_raw = (int16_t)(temp_buf[0] | (temp_buf[1] << 8));

    // Convert to physical units
    data->accel_g.x = (float)data->accel_raw.x / dev->accel_scale;
    data->accel_g.y = (float)data->accel_raw.y / dev->accel_scale;
    data->accel_g.z = (float)data->accel_raw.z / dev->accel_scale;

    data->gyro_dps.x = (float)data->gyro_raw.x / dev->gyro_scale;
    data->gyro_dps.y = (float)data->gyro_raw.y / dev->gyro_scale;
    data->gyro_dps.z = (float)data->gyro_raw.z / dev->gyro_scale;

    // Temperature: 23°C + raw/512
    if (temp_raw == (int16_t)0x8000) {
        data->temp_c = 0.0f;  // Invalid
    } else {
        data->temp_c = 23.0f + ((float)temp_raw / 512.0f);
    }

    data->sample_count++;
    return BMI270_OK;
}
