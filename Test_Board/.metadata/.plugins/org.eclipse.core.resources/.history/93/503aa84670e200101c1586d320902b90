/**
 * @brief Test 1: Check I2C communication and chip ID
 */
void Test_ChipID(void)
{
    printf("\r\n=== TEST 1: Chip ID Verification ===\r\n");

    uint8_t chip_id = 0;
    BMP388_Status status = BMP388_GetChipID(&bmp388, &chip_id);

    if (status == BMP388_OK) {
        printf("Chip ID: 0x%02X\r\n", chip_id);

        if (chip_id == BMP388_CHIP_ID) {
            printf("PASS: BMP388 detected!\r\n");
        } else if (chip_id == BMP390_CHIP_ID) {
            printf("PASS: BMP390 detected!\r\n");
        } else {
            printf("FAIL: Unknown chip ID (expected 0x50 or 0x60)\r\n");
        }
    } else {
        printf("FAIL: Could not read chip ID (status=%d)\r\n", status);
    }
}

/**
 * @brief Test 2: Read error register
 */
void Test_ErrorRegister(void)
{
    printf("\r\n=== TEST 2: Error Register ===\r\n");

    uint8_t err = 0;
    BMP388_Status status = BMP388_GetError(&bmp388, &err);

    if (status == BMP388_OK) {
        printf("Error Register: 0x%02X\r\n", err);

        if (err == 0x00) {
            printf("PASS: No errors\r\n");
        } else {
            if (err & 0x01) printf("  - Fatal error\r\n");
            if (err & 0x02) printf("  - Command error\r\n");
            if (err & 0x04) printf("  - Configuration error\r\n");
        }
    } else {
        printf("FAIL: Could not read error register\r\n");
    }
}

/**
 * @brief Test 3: Print calibration coefficients
 */
void Test_CalibrationData(void)
{
    printf("\r\n=== TEST 3: Calibration Coefficients ===\r\n");

    printf("Temperature coefficients:\r\n");
    printf("  PAR_T1: %u\r\n", bmp388.calib.par_t1);
    printf("  PAR_T2: %u\r\n", bmp388.calib.par_t2);
    printf("  PAR_T3: %d\r\n", bmp388.calib.par_t3);

    printf("Pressure coefficients:\r\n");
    printf("  PAR_P1:  %d\r\n", bmp388.calib.par_p1);
    printf("  PAR_P2:  %d\r\n", bmp388.calib.par_p2);
    printf("  PAR_P3:  %d\r\n", bmp388.calib.par_p3);
    printf("  PAR_P4:  %d\r\n", bmp388.calib.par_p4);
    printf("  PAR_P5:  %u\r\n", bmp388.calib.par_p5);
    printf("  PAR_P6:  %u\r\n", bmp388.calib.par_p6);
    printf("  PAR_P7:  %d\r\n", bmp388.calib.par_p7);
    printf("  PAR_P8:  %d\r\n", bmp388.calib.par_p8);
    printf("  PAR_P9:  %d\r\n", bmp388.calib.par_p9);
    printf("  PAR_P10: %d\r\n", bmp388.calib.par_p10);
    printf("  PAR_P11: %d\r\n", bmp388.calib.par_p11);

    // Sanity check: PAR_T1 should not be 0 or 0xFFFF
    if (bmp388.calib.par_t1 != 0 && bmp388.calib.par_t1 != 0xFFFF) {
        printf("PASS: Calibration data looks valid\r\n");
    } else {
        printf("FAIL: Calibration data may be corrupt\r\n");
    }
}

/**
 * @brief Test 4: Single measurement
 */
void Test_SingleMeasurement(void)
{
    printf("\r\n=== TEST 4: Single Measurement ===\r\n");

    BMP388_Data data;
    BMP388_Status status = BMP388_ReadData(&bmp388, &data);

    if (status == BMP388_OK) {
        printf("Temperature: %.2f C\r\n", data.temperature);
        printf("Pressure:    %.2f Pa (%.2f hPa)\r\n", data.pressure, data.pressure / 100.0);
        printf("Altitude:    %.2f m\r\n", data.altitude);

        // Sanity checks
        bool temp_ok = (data.temperature > -40.0 && data.temperature < 85.0);
        bool press_ok = (data.pressure > 30000.0 && data.pressure < 125000.0);

        if (temp_ok && press_ok) {
            printf("PASS: Values are within valid range\r\n");
        } else {
            if (!temp_ok) printf("WARN: Temperature out of range\r\n");
            if (!press_ok) printf("WARN: Pressure out of range\r\n");
        }
    } else {
        printf("FAIL: Could not read data (status=%d)\r\n", status);
    }
}

/**
 * @brief Test 5: Multiple measurements (stability test)
 */
void Test_MultipleMeasurements(void)
{
    printf("\r\n=== TEST 5: Stability Test (10 samples) ===\r\n");

    double temp_sum = 0, press_sum = 0;
    double temp_min = 1000, temp_max = -1000;
    double press_min = 200000, press_max = 0;
    int success_count = 0;

    for (int i = 0; i < 10; i++) {
        BMP388_Data data;
        BMP388_Status status = BMP388_ReadData(&bmp388, &data);

        if (status == BMP388_OK) {
            printf("[%d] T=%.2f C, P=%.2f hPa\r\n", i + 1, data.temperature, data.pressure / 100.0);

            temp_sum += data.temperature;
            press_sum += data.pressure;

            if (data.temperature < temp_min) temp_min = data.temperature;
            if (data.temperature > temp_max) temp_max = data.temperature;
            if (data.pressure < press_min) press_min = data.pressure;
            if (data.pressure > press_max) press_max = data.pressure;

            success_count++;
        } else {
            printf("[%d] FAIL\r\n", i + 1);
        }

        HAL_Delay(100);
    }

    if (success_count > 0) {
        printf("\r\nStatistics:\r\n");
        printf("  Avg Temperature: %.2f C\r\n", temp_sum / success_count);
        printf("  Temp Range: %.2f - %.2f C (delta=%.3f)\r\n", temp_min, temp_max, temp_max - temp_min);
        printf("  Avg Pressure: %.2f hPa\r\n", press_sum / success_count / 100.0);
        printf("  Press Range: %.2f - %.2f hPa (delta=%.3f)\r\n",
               press_min / 100.0, press_max / 100.0, (press_max - press_min) / 100.0);

        // Check noise level
        if ((temp_max - temp_min) < 1.0 && (press_max - press_min) < 50.0) {
            printf("PASS: Low noise, sensor is stable\r\n");
        } else {
            printf("WARN: High noise detected\r\n");
        }
    }
}

/**
 * @brief Continuous measurement loop
 */
void Test_ContinuousMode(void)
{
    printf("\r\n=== CONTINUOUS MODE (Ctrl+C to stop) ===\r\n");
    printf("Press reset to exit\r\n\r\n");

    while (1) {
        BMP388_Data data;
        BMP388_Status status = BMP388_ReadData(&bmp388, &data);

        if (status == BMP388_OK) {
            printf("T=%.2f C | P=%.2f hPa | Alt=%.1f m\r\n",
                   data.temperature,
                   data.pressure / 100.0,
                   data.altitude);
        } else {
            printf("Read error: %d\r\n", status);
        }

        HAL_Delay(500);
    }
}
