	(text "Flight Controller Design"
		(exclude_from_sim no)
		(at 60.452 21.59 0)
		(effects
			(font
				(size 5.08 5.08)
				(thickness 0.762)
				(bold yes)
			)
		)
		(uuid "7ffd1753-38b2-4444-934f-2df3ec34d533")
	)
	(text "ICM-42688P (primary IMU) - SPI\n\nBMI270 (backup IMU) - SPI\n\nBMP388 barometer - I²C\n\nMagnetometer (LIS3MDL) - I²C\n\n\nAT7456E OSD - SPI\n\nW25Q128 flash memory (16 Mbit) - SPI\n\nCAN transceiver (SN65HVD230) - FDCAN\n"
		(exclude_from_sim no)
		(at 97.917 241.554 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
				(color 255 255 255 1)
			)
		)
		(uuid "a32c203b-8954-438a-b90d-5af2d4ccddc2")
	)
	(text "Signal Bidirectional"
		(exclude_from_sim no)
		(at 589.788 78.867 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.4064)
				(bold yes)
			)
		)
		(uuid "b3812371-e376-4a25-99c1-63f4c9c75a84")
	)
	(text "8× motor outputs (PWM)\n\n4× servo outputs (PWM)\n\nGPS + compass port (UART + I²C)\n\nRC receiver (SBUS / ELRS UART)\n\nTelemetry UART\n\nCAN bus (4-pin)\n\nAirspeed (I²C)\n\nVTX (analog + 9/12 V)\n\nDJI FPV (UART + SBUS)\n\nUSB-C port"
		(exclude_from_sim no)
		(at 464.82 153.162 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
				(color 255 255 255 1)
			)
		)
		(uuid "bde741af-facd-4b6e-b2fa-391676b24bde")
	)
	(text "Comments"
		(exclude_from_sim no)
		(at 585.851 34.29 0)
		(effects
			(font
				(size 3.81 3.81)
				(thickness 0.762)
				(bold yes)
			)
		)
		(uuid "cb881141-80d6-4c15-873a-1a358a07089e")
	)
	(text "TVS + reverse polarity protection\n\nDual buck converters (5 V + 9/12 V)\n\nDual LDO rails (3.3V digital + 3.3V IMU)\n\nUSB-C power + automatic power switching\n\nBasic input filtering\n\nINA226 voltage/current monitor - I²C"
		(exclude_from_sim no)
		(at 94.742 91.44 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
				(color 255 255 255 1)
			)
		)
		(uuid "dc68396d-d2aa-4666-ab62-0efa91686378")
	)
	(text "MCU: STM32H743VIT6\nARM Cortex-M7 @ 480 MHz\n2 MB Flash, 1 MB RAM\nLQFP-100 Package\n\n\nHardware floating-point unit (FPU)\n\n16-bit/32-bit timers with PWM\n\n4× SPI, 4× I2C, 8× USART/UART\n\n2× FDCAN, USB OTG FS/HS\n\n3× 16-bit ADC (up to 36 channels)\n\nDMA with DMAMUX\n\nBuilt-in UART signal inversion\n\nOperating voltage: 1.71V - 3.6V"
		(exclude_from_sim no)
		(at 272.542 162.052 0)
		(effects
