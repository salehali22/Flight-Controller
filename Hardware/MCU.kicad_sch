	)
	(text "2) Motors PWM Pins were choosen to avoid\n   DMA conflicts, motors utilize both Advanced\n   timers TIM1 and TIM8 with 4 channels each.   "
		(exclude_from_sim no)
		(at 379.222 69.088 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.508)
				(bold yes)
