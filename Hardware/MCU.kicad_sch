	(text "4) On board Magnetometer and Airspeed\n   sensor module will share the same \n   I2C1 bus"
		(exclude_from_sim no)
		(at 379.984 142.24 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.4064)
				(bold yes)
			)
		)
		(uuid "3e008800-bc51-44da-94d6-aa5ffe479b57")
	)
	(text "mouting holes 3.2mm each, applicable \nfor M3 screws. maintin 30.5mm spaces \nin each direction in the layout\n"
		(exclude_from_sim no)
		(at 256.032 221.742 0)
		(effects
			(font
				(size 1.778 1.778)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "51a4d7c6-89f5-4553-abe0-82dae658f2ab")
	)
	(text "1) Instead of using a crystal resonator for\n   external clock source, We will use CMOS, \n   BYPASS clock oscillator. Safer to get right \n   and less hassle/requirements\n "
		(exclude_from_sim no)
		(at 377.698 41.91 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.508)
				(bold yes)
