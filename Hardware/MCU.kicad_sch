		(uuid "5edb7d3b-9a5f-4374-a590-e03f38cd9111")
	)
	(text "3) DJI_SBUS -> RC commands from DJI \n   controller to FC. \n   100kbps\n   inverted, RX pin only\n   (UART4_RX)"
