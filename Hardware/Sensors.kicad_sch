	)
	(text "1) Crystal Oscillator capacitor Calculation\n   Depends on the specific crystal capacitance\n   and stray capacitance. Take stray capacitance \n   to be 3 - 5 pF.\n "
		(exclude_from_sim no)
		(at 552.45 46.736 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "4516b42d-1482-446e-8d50-3db4a5a3778e")
	)
	(text "HIGH = (0x77) address\nLOW = (0x76) address"
		(exclude_from_sim no)
		(at 285.496 105.664 0)
		(effects
			(font
				(size 0.762 0.762)
				(thickness 0.1524)
