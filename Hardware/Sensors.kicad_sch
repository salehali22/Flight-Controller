				(thickness 0.762)
				(bold yes)
			)
		)
		(uuid "833361e3-1e9c-43ee-9474-c20b1188d826")
	)
	(text "2) A)CAN bus requires 120Ω termination resistors\n   at both physical ends of the bus only.\n   If the flight controller is positioned in\n   the middle of the CAN chain, no termination\n   should be installed. Populate R30 only\n   if the flight controller is at one end of the bus.\n\n   B) 0Ω Resistor on RS for slope control,\n      now its configured for High speed. If\n      the wires are long then 10kΩ - 100kΩ \n      should be used\n\n\n "
		(exclude_from_sim no)
		(at 552.958 101.092 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.4064)
				(bold yes)
