{
  "name": "drone-ground-station",
  "version": "1.0.0",
  "description": "Professional drone telemetry and configuration tool",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.dronegs.app",
    "productName": "Drone Ground Station",
    "files": [
      "src/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "electron": "^28.0.0",
    "three": "^0.160.0",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "electron-builder": "^24.9.0"
  }
}

